# Django
SECRET_KEY=your-secret-key-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DB_NAME=spt_mentoring
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379/0

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Email (set to smtp.office365.com for Microsoft 365 / Outlook)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.office365.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=mentoring@spt.org
EMAIL_HOST_PASSWORD=your-email-password
DEFAULT_FROM_EMAIL=mentoring@spt.org
MENTORING_FROM_EMAIL=mentoring@spt.org
SCHOLARSHIPS_FROM_EMAIL=scholarships@spt.org

# File storage (AWS S3 – leave USE_S3=False for local dev)
USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=eu-west-2

# Mentoring config
NO_CONTACT_REMINDER_DAYS=14
